{
	"name": "seopulse/seopulse",
	"description": "A WordPress plugin to optimize your content SEO for search engines.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"SEOPulse\\": ""
		},
		"files": [
			"Core/helpers.php"
		],
		"exclude-from-classmap": [
			"Core/helpers.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"SEOPulse\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^0.7 || ^1.0",
		"friendsofphp/php-cs-fixer": "^3.94",
		"mockery/mockery": "^1.5",
		"phpunit/phpunit": "^9.5",
		"squizlabs/php_codesniffer": "^3.7",
		"wp-coding-standards/wpcs": "3.0"
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-html tests/coverage",
		"test:filter": "phpunit --filter",
		"cs-check": "phpcs --standard=PSR12 Core/ Modules/ Admin/ Api/ Services/",
		"cs-fix": "phpcbf --standard=PSR12 Core/ Modules/ Admin/ Api/ Services/",
		"fixer": "php-cs-fixer fix --verbose",
		"fixer-dry": "php-cs-fixer fix --dry-run --diff --verbose"
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
